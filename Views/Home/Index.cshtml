@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Grupo Genial</h1>
    <img src="data:image/jpeg;base64,   " alt="Grupo Genial" width="400" height="300">
    @foreach(int clave in ViewBag.integrantes.Keys)
    {
        <p>
            <a href="@Url.Action("SelectIntegrante", "Home", new { dni = clave })"> @ViewBag.integrantes[clave].getNombre() </a>
            <img src="@ViewBag.integrantes[clave].getFoto()"/>
        </p>
    }
    
</div>
